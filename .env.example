# --- 共通 ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Podcast Mode: 台本生成（Claude API） ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
PODCAST_SCRIPT_MODEL=claude-sonnet-4-6          # optional: claude-opus-4-7 / claude-haiku-4-5-20251001

# --- Podcast Mode: TTS（ElevenLabs ハイブリッド戦略） ---
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_VOICE_ID_ENGLISH_MALE=pNInz6obpgDQGcFmaJgB  # Adam (default)
ELEVENLABS_VOICE_ID_USER_JA=your-cloned-voice-id-here   # required: Voice Cloning で事前作成
PODCAST_TTS_MODEL=eleven_multilingual_v2                  # optional: eleven_turbo_v2_5 / eleven_flash_v2_5
PODCAST_TTS_PROVIDER=elevenlabs                           # optional: elevenlabs / openai / edge
PODCAST_BGM_PATH=assets/podcast_bgm.mp3                   # optional
